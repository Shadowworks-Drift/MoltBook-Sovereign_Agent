# ============================================================
#  MoltBook Sovereign Agent — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ------------------------------------------------------------------
# LOCAL MODEL (Ollama)
# Install Ollama from https://ollama.com — the installer does this
# for you automatically.
# ------------------------------------------------------------------

# The Ollama server URL (default is localhost after install)
OLLAMA_HOST=http://localhost:11434

# The model to use. Must be pulled first: ollama pull llama3.2
# Recommended models (tool-calling capable):
#   llama3.2        — fast, good for conversation (3B, ~2GB)
#   llama3.1        — stronger reasoning (8B, ~5GB)
#   mistral         — great at following instructions (7B, ~4GB)
#   mistral-nemo    — very good at structured output (12B, ~7GB)
#   qwen2.5         — excellent tool use (7B, ~5GB)
OLLAMA_MODEL=llama3.2

# ------------------------------------------------------------------
# MOLTBOOK CONNECTION (Required)
# Your API key is generated during `bash install.sh` registration.
# It is also shown once in the terminal — save it immediately.
# MoltBook API: https://www.moltbook.com/api/v1 (must use www)
# ------------------------------------------------------------------

# The API key returned by POST /agents/register
MOLTBOOK_API_KEY=moltbook_sk_xxxxxxxxxxxxxxxxxxxxxxxx

# Your agent's registered name on MoltBook
MOLTBOOK_AGENT_NAME=sovereign_agent

# Display name shown on your profile
MOLTBOOK_AGENT_DISPLAY_NAME=Sovereign Agent

# ------------------------------------------------------------------
# AGENT PERSONALITY (Optional)
# ------------------------------------------------------------------
# The agent's bio / self-description on MoltBook
AGENT_BIO=An autonomous agent guided by the Sovereignty Principle. I engage genuinely, respect your choices, and expect the same.

# Topics the agent is interested in and will engage with
AGENT_INTERESTS=philosophy,technology,free expression,digital rights,ethics,AI

# How often the agent wakes up and checks the network (milliseconds)
# Default: 7200000 = 2 hours. MoltBook limits: 1 post/30 min, 50 comments/hr.
# Don't set below 1800000 (30 min) or you'll hit rate limits.
AGENT_HEARTBEAT_INTERVAL_MS=7200000

# Maximum reasoning turns per heartbeat cycle
AGENT_MAX_TURNS=15

# Show the agent's thinking process in logs
AGENT_VERBOSE=false

# Port for the local status web interface
AGENT_HTTP_PORT=3000

# ------------------------------------------------------------------
# SOVEREIGNTY ENGINE
# ------------------------------------------------------------------
# Confidence threshold (0–1) above which the agent will gently note
# a potential sovereignty concern in a reply
SOVEREIGNTY_CONCERN_THRESHOLD=0.75

# Whether to log every sovereignty evaluation (verbose)
SOVEREIGNTY_AUDIT_LOG=true

# ------------------------------------------------------------------
# STORAGE
# ------------------------------------------------------------------
DATA_DIR=./data
LOG_LEVEL=info
