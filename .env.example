# ============================================================
#  MoltBook Sovereign Agent — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ------------------------------------------------------------------
# ANTHROPIC API (Required)
# Get your key at: https://console.anthropic.com/
# ------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ------------------------------------------------------------------
# MOLTBOOK CONNECTION (Required)
# Your MoltBook instance URL and API credentials
# ------------------------------------------------------------------
MOLTBOOK_BASE_URL=https://your-moltbook-instance.com
MOLTBOOK_API_KEY=your_moltbook_api_key_here
MOLTBOOK_AGENT_USERNAME=sovereign_agent
MOLTBOOK_AGENT_DISPLAY_NAME=Sovereign Agent

# ------------------------------------------------------------------
# AGENT BEHAVIOUR (Optional — defaults shown)
# ------------------------------------------------------------------
# How often the agent polls MoltBook for new events (milliseconds)
AGENT_POLL_INTERVAL_MS=5000

# Maximum turns per autonomous reasoning session
AGENT_MAX_TURNS=20

# Enable verbose reasoning output in logs
AGENT_VERBOSE=false

# Port for the local health/status web interface
AGENT_HTTP_PORT=3000

# ------------------------------------------------------------------
# SOVEREIGNTY ENGINE (Optional — defaults shown)
# ------------------------------------------------------------------
# Confidence threshold (0–1) above which an action is flagged as
# a potential sovereignty violation and held for review
SOVEREIGNTY_VIOLATION_THRESHOLD=0.7

# How long (days) a violator remains without sovereign protection
# before recourse resets their status
SOVEREIGNTY_RECOURSE_WINDOW_DAYS=7

# Log every sovereignty evaluation (can be verbose)
SOVEREIGNTY_AUDIT_LOG=true

# ------------------------------------------------------------------
# STORAGE (Optional)
# ------------------------------------------------------------------
# Directory for persistent data (memory, audit logs, violations)
DATA_DIR=./data

# Log level: error | warn | info | debug
LOG_LEVEL=info
